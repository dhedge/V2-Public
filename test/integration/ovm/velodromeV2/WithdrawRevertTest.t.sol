pragma solidity 0.7.6;
pragma experimental ABIEncoderV2;

import {Test} from "forge-std/Test.sol";

contract WithdrawRevertTest is Test {
  address public constant POOL = 0xCc65077153fCC0DD2B12da8D387f66258b53a80F;

  function test_withdrawSafe_reverts_on_block_145760000() public {
    vm.createSelectFork("optimism", 145760000);
    vm.prank(0x26c0Bf69D95442B84e3e789359156aCf96FeddA6);
    (bool result, ) = POOL.call(
      hex""
    );
    assertFalse(result);
  }

  function test_withdrawSafe_does_not_revert_on_block_146104698() public {
    vm.createSelectFork("optimism", 146104698);
    vm.prank(0x26c0Bf69D95442B84e3e789359156aCf96FeddA6);
    (bool result, ) = POOL.call(
      hex""
    );
    assertTrue(result);
  }
}
