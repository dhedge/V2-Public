pragma solidity 0.7.6;
pragma abicoder v2;

import {AngleDistributorContractGuard} from "contracts/guards/contractGuards/AngleDistributorContractGuard.sol";
import {AngleDistributorContractGuardTestSetup} from "test/integration/common/angle/AngleDistributorContractGuardTestSetup.t.sol";
import {DeploymentDryRunPlasma} from "test/integration/utils/foundry/dryRun/DeploymentDryRunPlasma.t.sol";
import {PlasmaConfig} from "test/integration/utils/foundry/config/PlasmaConfig.sol";

contract AngleDistributorContractGuardPlasmaTest is AngleDistributorContractGuardTestSetup, DeploymentDryRunPlasma {
  address private constant WRAPPED_A_USDT_TOKEN = 0x9421F7A094c299AF6d4451E68bA7bEC09a8a062D;
  address private constant WXPL_TOKEN = 0x6100E367285b01F48D07953803A2d8dCA5D19873;
  address private constant DHEDGE_POOL = 0x461263Bff57cBaFe3994b15A5e4d388c50d4D9Fe;

  constructor()
    AngleDistributorContractGuardTestSetup(
      DHEDGE_POOL,
      PlasmaConfig.AAVE_V3_LENDING_POOL,
      hex""
    )
    DeploymentDryRunPlasma(17014676, new address[](0))
  {
    // Wrapped aUSDT: unwraps to USDT, increases TVL
    _addRewardTokenConfig(
      RewardTokenTestConfig({
        token: PlasmaConfig.USDT,
        wrappedToken: WRAPPED_A_USDT_TOKEN,
        tokenType: AngleDistributorContractGuard.RewardTokenType.WRAPPED_REGULAR
      })
    );

    // WXPL: not supported asset, balance increases but does not affect TVL
    _addRewardTokenConfig(
      RewardTokenTestConfig({
        token: WXPL_TOKEN,
        wrappedToken: address(0),
        tokenType: AngleDistributorContractGuard.RewardTokenType.REGULAR_NOT_SUPPORTED
      })
    );
  }

  function setUp() public override {
    super.setUp();
    _deployContractGuard(poolFactory);
  }
}
